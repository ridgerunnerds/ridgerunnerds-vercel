{
  "version": 2,
  "buildCommand": null,
  "installCommand": null,
  "framework": null,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/ridge-runner", "dest": "/" },
    { "src": "/ridge-runner/(.*)", "dest": "/" },
    { "src": "/yyc-tax-sale/[^.]+", "dest": "/yyc-tax-sale/index.html" },
